<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Safe zone: 18–90 (72×72). Design lives at 24–84 (60×60), centered at 54,54.

        Layout (all paths in 108×108 viewport):
          • 4 corner L-brackets  → #00FFAA (cyan-green, matches app OCR box color)
          • 4 text-line bars     → white, varying widths & opacity
          • 1 scan beam + glow  → #00FFAA
    -->

    <!-- ── Corner brackets ── -->

    <!-- Top-left  M start,go-right,down,left,down,left,close -->
    <path
        android:fillColor="#00FFAA"
        android:pathData="M24,24 h14 v4 h-10 v10 h-4 Z" />

    <!-- Top-right -->
    <path
        android:fillColor="#00FFAA"
        android:pathData="M84,24 h-14 v4 h10 v10 h4 Z" />

    <!-- Bottom-left -->
    <path
        android:fillColor="#00FFAA"
        android:pathData="M24,84 h14 v-4 h-10 v-10 h-4 Z" />

    <!-- Bottom-right -->
    <path
        android:fillColor="#00FFAA"
        android:pathData="M84,84 h-14 v-4 h10 v-10 h4 Z" />

    <!-- ── Text lines (above scan beam, bright) ── -->

    <!-- Line 1: full width -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M34,40 h40 v4 h-40 Z" />

    <!-- Line 2: 75% width -->
    <path
        android:fillColor="#CCFFFFFF"
        android:pathData="M34,48 h30 v4 h-30 Z" />

    <!-- ── Scan beam with soft glow ── -->

    <!-- Glow halo (wide, low alpha) -->
    <path android:pathData="M24,53 h60 v8 h-60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="53"
                android:endX="54"
                android:endY="61"
                android:startColor="#5500FFAA"
                android:endColor="#0000FFAA" />
        </aapt:attr>
    </path>

    <!-- Beam core (sharp, bright) -->
    <path
        android:fillColor="#00FFAA"
        android:pathData="M24,56 h60 v2 h-60 Z" />

    <!-- ── Text lines (below scan beam, dimmed) ── -->

    <!-- Line 3: full width -->
    <path
        android:fillColor="#88FFFFFF"
        android:pathData="M34,62 h40 v4 h-40 Z" />

    <!-- Line 4: 55% width -->
    <path
        android:fillColor="#55FFFFFF"
        android:pathData="M34,70 h22 v4 h-22 Z" />

</vector>
